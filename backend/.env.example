# Copy to backend/.env — used when running backend locally (npm run dev, npx prisma ...)
# cp .env.example .env
#
# NOT used for DATABASE_URL when running via Docker Compose — compose overrides with postgres:5432

# Local machine → Docker Postgres (host port 5433 maps to container 5432)
DATABASE_URL=postgresql://lokhari:change_me@127.0.0.1:5433/lokhari-db

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# reCAPTCHA v2 (contact form server verification)
RECAPTCHA_SECRET_KEY=your_secret_key

# Contact form notification recipient
CONTACT_NOTIFY_EMAIL=support@lokhari.com
