# Copy to backend/.env — used when running backend locally (npm run dev, npx prisma ...)
# cp .env.example .env
#
# NOT used for DATABASE_URL when running via Docker Compose — compose overrides with postgres:5432

# Local machine → Docker Postgres (host port 5433 maps to container 5432)
DATABASE_URL=postgresql://lokhari:change_me@127.0.0.1:5433/lokhari-db

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# reCAPTCHA v2 (contact form server verification)
RECAPTCHA_SECRET_KEY=your_secret_key

# Contact form notification recipient
CONTACT_NOTIFY_EMAIL=support@lokhari.com

# ── Email (OTP + contact notifications) ──────────────────────────────────────
#
# OPTION 1 — Resend HTTP API (RECOMMENDED for Render / cloud deployments)
#   Sign up free at https://resend.com → API Keys → Create Key
#   Free tier: 3 000 emails/month, 100/day
#   No SMTP ports needed — works everywhere.
#
RESEND_API_KEY=re_cBMrhMSC_LKcGjdvoc21gNARPeoAmwxbP
EMAIL_FROM=Lokari <noreply@yourdomain.com>
#
# OPTION 2 — SMTP (works locally; Render blocks port 587, use 465)
#   Gmail: enable 2FA → generate an App Password at myaccount.google.com/apppasswords
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=your_16char_app_password
# SMTP_FROM=yourname@gmail.com
