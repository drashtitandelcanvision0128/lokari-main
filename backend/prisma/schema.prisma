// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  FARMER
  WAREHOUSE_OWNER
  TRADER
  TRANSPORTER
  ADMIN
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ListingType {
  PRODUCE
  WAREHOUSE
  TRANSPORT
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  EXPIRED
}

enum ListingVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PriceType {
  FIXED_PRICE
  NEGOTIABLE
  AUCTION
}

enum AuctionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum BidStatus {
  ACTIVE
  OUTBID
  WON
  LOST
}

enum ContactInquiryStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model ContactInquiry {
  inquiry_id String               @id @default(uuid())
  name       String
  email      String
  subject    String
  message    String               @db.Text
  status     ContactInquiryStatus @default(NEW)
  created_at DateTime             @default(now())
  updated_at DateTime             @updatedAt

  @@map("contact_inquiries")
}

model User {
  user_id     String        @id @default(uuid())
  name        String?
  email       String        @unique
  phone       String?       @unique
  password    String
  role        UserRole      @default(FARMER)
  is_verified Boolean       @default(false)
  is_active   Boolean       @default(true)
  is_deleted  Boolean       @default(false)
  profile     UserProfile?
  addresses   Address[]
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  listings    Marketplace[]
  bids        Bid[]

  @@map("users")
}

model UserProfile {
  profile_id String @id @default(uuid())
  user_id    String @unique

  avatar_url String?
  bio        String?
  kyc_status KycStatus @default(PENDING)

  farm_name          String?
  farm_location      String?
  company_name       String?
  business_type      String?
  warehouse_name     String?
  warehouse_location String?
  capacity           String?
  vehicle_type       String?
  service_area       String?

  user User @relation(fields: [user_id], references: [user_id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("user_profiles")
}

model Address {
  address_id String @id @default(uuid())
  user_id    String

  street  String
  city    String
  state   String
  pincode String
  country String

  lat Float?
  lng Float?

  is_default Boolean @default(false)

  user User @relation(fields: [user_id], references: [user_id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("addresses")
}

model Marketplace {
  listing_id String @id @default(uuid())
  user_id    String

  type             ListingType
  title            String
  description      String?
  listing_location String?

  product_images String[] @default([])

  price      Decimal
  price_type PriceType     @default(FIXED_PRICE)
  status     ListingStatus @default(DRAFT)

  verification_status ListingVerificationStatus @default(PENDING)

  is_deleted Boolean @default(false)
  is_blocked Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user          User                @relation(fields: [user_id], references: [user_id])
  address       MarketplaceAddress?
  farmerProduce FarmerProduce?
  warehouse     Warehouse?
  transport     Transport?
  auction       Auction?

  @@map("marketplace")
}

model MarketplaceAddress {
  marketplace_address_id String @id @default(uuid())

  listing_id String @unique

  street  String?
  city    String
  state   String
  pincode String
  country String

  lat Float?
  lng Float?

  listing    Marketplace @relation(fields: [listing_id], references: [listing_id])
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt

  @@map("marketplace_addresses")
}

model FarmerProduce {
  produce_listing_id String @id @default(uuid())
  listing_id         String @unique

  crop_type     String
  variety       String?
  quantity      Decimal
  unit          String
  harvest_date  DateTime?
  expiry_date   DateTime?
  quality_grade String?

  min_order_quantity Decimal?
  min_order_unit     String?

  storage_temperature String?
  storage_humidity    String?

  listing Marketplace @relation(fields: [listing_id], references: [listing_id])

  @@map("farmer_produces")
}

model Warehouse {
  warehouse_listing_id String @id @default(uuid())
  listing_id           String @unique

  warehouse_id String?

  capacity           Decimal
  capacity_unit      String
  available_from     DateTime?
  available_to       DateTime?
  climate_controlled Boolean   @default(false)

  listing Marketplace @relation(fields: [listing_id], references: [listing_id])

  @@map("warehouses")
}

model Transport {
  transport_listing_id String @id @default(uuid())
  listing_id           String @unique

  vehicle_id String?

  vehicle_type    String
  capacity        Decimal
  capacity_unit   String
  available_from  DateTime?
  available_to    DateTime?
  is_refrigerated Boolean   @default(false)

  listing Marketplace @relation(fields: [listing_id], references: [listing_id])

  @@map("transports")
}

model Auction {
  auction_id String @id @default(uuid())

  listing_id String @unique

  start_time DateTime
  end_time   DateTime

  reserve_price       Decimal?
  starting_bid        Decimal
  current_highest_bid Decimal?

  status AuctionStatus @default(SCHEDULED)

  winner_bid_id String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  listing Marketplace @relation(fields: [listing_id], references: [listing_id])
  bids    Bid[]

  @@map("auctions")
}

model Bid {
  bid_id String @id @default(uuid())

  auction_id String
  bidder_id  String

  amount Decimal

  status BidStatus @default(ACTIVE)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  auction Auction @relation(fields: [auction_id], references: [auction_id])
  bidder  User    @relation(fields: [bidder_id], references: [user_id])

  @@map("bids")
}
