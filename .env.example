# Copy to .env in this folder (project root) — used by Docker Compose
# cp .env.example .env

# Postgres container credentials
POSTGRES_USER=lokhari
POSTGRES_PASSWORD=abcd123
POSTGRES_DB=lokhari-db

# Used by Docker backend (host "postgres" = Compose service name, internal port 5432)
# Compose builds DATABASE_URL automatically from POSTGRES_* vars above
DATABASE_URL=postgresql://lokhari:abcd123@postgres:5432/lokhari-db

# Backend auth
JWT_SECRET=abcd
JWT_EXPIRES_IN=7d
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:3000

# Frontend (baked in at Docker build time)
NEXT_PUBLIC_API_URL=http://localhost:5000

# DBeaver / local tools: connect to 127.0.0.1:5433 (not 5432 — Windows may have another Postgres there)
# Username: lokhari | Database: lokhari-db | Password: same as POSTGRES_PASSWORD in your .env
