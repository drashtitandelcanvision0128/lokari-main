# Copy to .env in this folder (project root) — used by Docker Compose
# cp .env.example .env

# Postgres container credentials
POSTGRES_USER=lokhari
POSTGRES_PASSWORD=abcd123
POSTGRES_DB=lokhari-db

# Used by Docker backend (host "postgres" = Compose service name, internal port 5432)
# Compose builds DATABASE_URL automatically from POSTGRES_* vars above
DATABASE_URL=postgresql://lokhari:abcd123@postgres:5432/lokhari-db

# Backend auth
JWT_SECRET=abcd
JWT_EXPIRES_IN=7d
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:3000

# Frontend — use host only (no /api) until backend deploys /api routes
# After backend deploy: optional https://lokhari-api.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000

# Redis — OTP storage (Docker: redis://redis:6379 | local: redis://127.0.0.1:6379)
REDIS_URL=redis://127.0.0.1:6379

# Email (SMTP) — required for Docker backend (reads from THIS root .env file)
# Ethereal: create account at https://ethereal.email/create then view inbox at /messages
# SMTP_HOST=smtp.ethereal.email
# SMTP_PORT=587
# SMTP_USER=your-user@ethereal.email
# SMTP_PASS=your-ethereal-password
# SMTP_FROM="Lokhari <noreply@lokhari.com>"

# OTP settings (optional)
# OTP_TTL_SECONDS=600
# OTP_MAX_ATTEMPTS=5
# OTP_RATE_LIMIT=3
# OTP_SECRET=use-a-long-random-string

# reCAPTCHA v2 checkbox (contact form) — https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# Contact form — team inbox for new inquiries (defaults to support@lokhari.com)
CONTACT_NOTIFY_EMAIL=support@lokhari.com

# DBeaver / local tools: connect to 127.0.0.1:5433 (not 5432 — Windows may have another Postgres there)
# Username: lokhari | Database: lokhari-db | Password: same as POSTGRES_PASSWORD in your .env
